<style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;700;900&family=Nunito:wght@400;600;800&display=swap');

    @media screen and (min-width: 391px) {
        .btn-light-effect { 
            position: relative; 
            overflow: hidden; 
            z-index: 1; 
            transition: all 0.3s ease; 
        }

        .btn-light-effect span { 
            position: relative; 
            z-index: 2; 
        }

        .btn-light-effect::before {
            content: ""; 
            position: absolute; 
            top: 0; 
            left: -300%; /* Começa bem fora da tela */
            width: 300%; 
            height: 300%;
            /* O segredo: as paradas de cor (0%, 45%, 50%, 55%, 100%) criam uma linha fina */
            background: linear-gradient(
                120deg, 
                transparent 40%, 
                rgba(255, 255, 255, 0.315) 50%, 
                transparent 60%
            );
            transition: all 3s cubic-bezier(0.19, 1, 0.22, 1); /* Transição mais elegante */
            z-index: 1;
        }

        .btn-light-effect:hover::before { 
            left: 150%; /* Atravessa a tela inteira */
        }
    }
    
    @media screen and (max-width: 390px) {
        .btn-light-effect { 
            position: relative; 
            overflow: hidden; 
            z-index: 1; 
            transition: all 0.3s ease; 
        }

        .btn-light-effect span { 
            position: relative; 
            z-index: 2; 
        }

        .btn-light-effect::before {
            content: ""; 
            position: absolute; 
            top: 0; 
            left: -900%; /* Começa bem fora da tela */
            width: 900%; 
            height: 300%;
            /* O segredo: as paradas de cor (0%, 45%, 50%, 55%, 100%) criam uma linha fina */
            background: linear-gradient(
                120deg, 
                transparent 40%, 
                rgba(255, 255, 255, 0.315) 50%, 
                transparent 60%
            );
            transition: all 3s cubic-bezier(0.19, 1, 0.22, 1); /* Transição mais elegante */
            z-index: 1;
        }

        .btn-light-effect:hover::before { 
            left: 150%; /* Atravessa a tela inteira */
        }
    }

    @media screen and (max-width: 390px) { 
        .div-overflow-wrap {
            overflow-wrap: break-word; 
        }
    }

    /* Seção de Citação - Estilo Premium 2026 */
    .quote-section {
        position: relative;
        padding: 100px 0;
        /* Substitua pelo caminho real da sua imagem de fundo */
        background: linear-gradient(rgba(19, 49, 92, 0.9), rgba(19, 49, 92, 0.9)), 
                    url('/img/fundo-tecnologico.jpg'); 
        background-attachment: fixed; /* Efeito Parallax */
        background-size: cover;
        background-position: center;
        border-radius: 80px; /* Bordas arredondadas conforme o seu site */
        margin: 60px 20px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* Brilho pulsante sutil no fundo (substitui o efeito de hover) */
    .quote-section::after {
        content: "";
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
        animation: pulse-glow 8s infinite alternate;
        z-index: 1;
    }

    @keyframes pulse-glow {
        0% { transform: translate(-10%, -10%); opacity: 0.5; }
        100% { transform: translate(10%, 10%); opacity: 0.8; }
    }

    .quote-content {
        position: relative;
        z-index: 2; /* Garante que o texto fique acima do brilho */
    }

    .quote-text {
        font-family: 'Poppins', sans-serif;
        font-style: italic;
        line-height: 1.4;
        text-shadow: 0 2px 10px rgba(0,0,0,0.3);
    }

    .divider-glow {
        height: 3px;
        width: 60px;
        background: linear-gradient(90deg, transparent, #006aff, transparent);
        margin: 30px auto;
    }

    .badge-reflexao {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(5px);
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 0.8rem;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    :root {
        --section-blue: #13315cd9;
        --primary-blue: #2568f8;
        --secundary-blue: #2b83ff;
        --terciary-blue: #2b83ff;
        --fourth-blue: #1652a7;
        --accent-blue: #006aff;
        --accent-orange: #ff8c42;
        --accent-green: #2a7428;
        --primary-green: #39a035;
        --secundary-green: #38a735;
        --accent-red: #f94144;
        --primary-red: #fc595c;
        --bg-soft: #f0f4f8;
        --white: #ffffff;
        --black: #000000;
    }

    body { font-family: 'Nunito', sans-serif; background-color: var(--white); color: #2d3436; overflow-x: hidden; }
    h1, h2, h3, h4, h5, h6 { font-family: 'Poppins', sans-serif; }

    /* Estilo Arredondado e Moderno */
    .rounded-huge { border-radius: 4rem !important; }
    .rounded-soft { border-radius: 2.5rem !important; }
    .btn-round { border-radius: 50px; padding: 14px 30px; font-weight: 700; transition: 0.3s; border: none; }
    
    /* Hero Section */
    .hero-gradient {
        background: radial-gradient(circle at top right, #eef2f7, var(--white));
        padding: 80px 0;
        border-radius: 0 0 100px 100px;
        border-bottom: 5px solid var(--primary-blue);
    }

    /* Cards e Efeitos de Flutuação */
    .floating-card {
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: none !important;
        background: var(--white);
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        border-radius: 2rem !important;
    }
    .floating-card:hover {
        transform: translateY(-15px);
        box-shadow: 0 30px 60px rgba(0,0,0,0.12) !important;
    }

    .floating-section {
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: none !important;
        background: #13315c;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        border-radius: 2rem !important;
        color: #333; 
    }

    .floating-section:hover {
        transform: translateY(-15px);
        background: #13315c !important;
        box-shadow: 0 30px 60px rgba(19, 49, 92, 0.5) !important;
        color: #ffffff !important;
    }

    .floating-section:hover h1, 
    .floating-section:hover h2, 
    .floating-section:hover p,
    .floating-section:hover span {
        color: #ffffff !important;
    }

    /* Citações Estilizadas */
    .quote-card {
        background: var(--white);
        border-left: 8px solid var(--primary-blue);
        padding: 2rem;
        border-radius: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        font-style: italic;
    }

    .divider-custom {
        height: 6px;
        width: 100px;
        background: linear-gradient(to right, var(--primary-blue), var(--primary-blue));
        border-radius: 10px;
        margin: 25px 0;
    }

    .img-side {
        width: 100%;
        border-radius: 3.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.2);
        transition: 0.5s;
    }
    .img-side:hover { transform: scale(1.02); }

    /* Overlay para seção de citação final */
    .quote-section {
        position: relative;
        padding: 120px 0;
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        border-radius: 100px;
        margin: 50px 20px;
        overflow: hidden;
    }
    .quote-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(19, 49, 92, 0.85);
    }
    .feature-icon { font-size: 2.5rem; color: var(--primary-blue); margin-bottom: 1rem; }
</style>

<header class="hero-gradient mb-5">
